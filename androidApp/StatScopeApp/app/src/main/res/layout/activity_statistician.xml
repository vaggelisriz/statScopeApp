<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".StatisticianActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_back_dashboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back to login"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#00E676" />

        <TextView
            android:id="@+id/tv_dashboard_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/rajdhani_bold"
            android:text="STATISTICIAN DASHBOARD"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />
    </LinearLayout>

    <View
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:layout_marginStart="60dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="40dp"
        android:background="#00E676" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/rajdhani_bold"
        android:letterSpacing="0.1"
        android:text="MATCH DAY"
        android:textColor="#555d8a"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_start_match"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#00E676"
        android:fontFamily="@font/rajdhani_bold"
        android:text="START LIVE MATCH"
        android:textColor="#01051a"
        android:textSize="18sp"
        app:cornerRadius="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/rajdhani_bold"
        android:letterSpacing="0.1"
        android:text="ADMINISTRATION"
        android:textColor="#555d8a"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_manage_teams"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#FFFFFF"
        android:fontFamily="@font/rajdhani_bold"
        android:text="TEAMS &amp; PLAYERS"
        android:textColor="#01051a"
        android:textSize="16sp"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/btn_manage_championships"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:backgroundTint="#FFFFFF"
        android:fontFamily="@font/rajdhani_bold"
        android:text="CHAMPIONSHIP SETUP"
        android:textColor="#01051a"
        android:textSize="16sp"
        app:cornerRadius="8dp" />

</LinearLayout>