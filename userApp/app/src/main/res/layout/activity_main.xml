<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.65" />

    <ImageView
        android:id="@+id/iv_logo_symbol"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:src="@drawable/logo_short"
        app:layout_constraintHeight_percent="0.25"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/iv_logo_text"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45" />

    <ImageView
        android:id="@+id/iv_logo_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/logo_long"
        android:layout_marginTop="4dp"
        app:layout_constraintWidth_percent="0.6"
        app:layout_constraintTop_toBottomOf="@+id/iv_logo_symbol"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/guideline_buttons" />

    <FrameLayout
        android:id="@+id/swipe_container"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/swipe_background"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintTop_toBottomOf="@+id/guideline_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_swipe_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Swipe to Enter >>"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:textSize="16sp"
            android:alpha="0.7" />

        <ImageView
            android:id="@+id/iv_swipe_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="4dp"
            android:background="@drawable/swipe_button_circle"
            android:src="@android:drawable/ic_media_play"
            android:padding="12dp"
            android:contentDescription="Swipe thumb" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>