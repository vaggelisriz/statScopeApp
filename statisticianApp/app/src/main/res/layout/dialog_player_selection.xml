<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#01051a"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/btn_close_dialog"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back_arrow"
            app:tint="#00E676" />

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/btn_close_dialog"
            android:fontFamily="sans-serif-condensed"
            android:text="SELECT LINEUP"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:id="@+id/accent_line_dialog"
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:layout_marginStart="56dp"
        android:layout_marginTop="2dp"
        android:background="#00E676" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_selection_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btn_confirm_selection"
            android:layout_marginEnd="12dp"
            android:fontFamily="sans-serif-condensed"
            android:text="Select 11 starting players"
            android:textColor="#9E9E9E"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_confirm_selection"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:backgroundTint="#444444"
            android:enabled="false"
            android:fontFamily="sans-serif-condensed"
            android:text="DONE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="8dp" />
    </RelativeLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#1AFFFFFF" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dialog_players"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>