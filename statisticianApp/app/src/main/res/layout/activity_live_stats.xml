<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btn_back_control"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00E676" />

    <TextView
        android:id="@+id/tv_control_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="sans-serif-condensed"
        android:text="MATCH LIVE PANEL"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_control"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_back_control"
        app:layout_constraintTop_toTopOf="@+id/btn_back_control" />

    <View
        android:id="@+id/accent_line"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:background="#00E676"
        app:layout_constraintStart_toStartOf="@+id/tv_control_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_control_title" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/accent_line">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#131833"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/iv_live_home_logo"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginBottom="6dp"
                            android:src="@android:drawable/ic_menu_gallery" />
                        <TextView
                            android:id="@+id/tv_live_home_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="HOME"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tv_live_home_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:text=":"
                            android:textColor="#00E676"
                            android:textSize="30sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_live_away_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/iv_live_away_logo"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginBottom="6dp"
                            android:src="@android:drawable/ic_menu_gallery" />
                        <TextView
                            android:id="@+id/tv_live_away_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="AWAY"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="1. SELECT TARGET"
                android:textColor="#00E676"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_selector_team"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="#131833"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="Select Team"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_selector_player"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="#131833"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="Select Player"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="2. RECORD MATCH ACTION"
                android:textColor="#00E676"
                android:textSize="13sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:columnOrderPreserved="false">

                <Button
                    android:id="@+id/btn_live_shot"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#00E676"
                    android:text="SHOTS"
                    android:textColor="#01051a"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_tackle"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="TACKLES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_pass"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="PASSES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_cross"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="CROSSES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_assist"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="ASSISTS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_turnover"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="ERRORS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_fouls"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="FOULS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_corner"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="CORNERS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />

                <Button
                    android:id="@+id/btn_live_cards"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:backgroundTint="#131833"
                    android:text="CARDS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="6dp" />
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="LIVE FEED LOG"
                android:textColor="#00E676"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_live_feed"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="8dp"
                android:background="#131833"
                android:padding="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>