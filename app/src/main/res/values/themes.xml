<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Frontend" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#01051a</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">#00E676</item>
        <item name="colorSecondaryVariant">#00c853</item>
        <item name="colorOnSecondary">#01051a</item>

        <item name="android:statusBarColor">#01051a</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="CircleImage" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">50%</item>
    </style>

    <style name="CustomDarkDialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">#131833</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="colorAccent">#00E676</item>
    </style>

</resources>