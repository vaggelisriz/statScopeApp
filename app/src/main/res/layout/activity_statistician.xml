<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp"
    tools:context=".StatisticianActivity">

    <ImageButton
        android:id="@+id/btn_back_dashboard"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back to Main Dashboard"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00E676"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/tv_dashboard_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="sans-serif-condensed"
        android:text="STATISTICIAN DASHBOARD"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_dashboard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_back_dashboard"
        app:layout_constraintTop_toTopOf="@+id/btn_back_dashboard"
        tools:ignore="HardcodedText" />

    <View
        android:id="@+id/accent_line"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:background="#00E676"
        app:layout_constraintStart_toStartOf="@+id/tv_dashboard_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_dashboard_title" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_set_match"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        app:cardBackgroundColor="#131833"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintWidth_percent="0.95"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/accent_line">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:minHeight="115dp">

            <TextView
                android:id="@+id/tv_title_set_match"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="sans-serif-condensed"
                android:text="Set Match Live"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/btn_set_match_live"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_set_match_live_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="16dp"
                android:text="Select a match, configure lineups, and start the game live."
                android:textColor="#888888"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@+id/btn_set_match_live"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_title_set_match"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/btn_set_match_live"
                android:layout_width="85dp"
                android:layout_height="48dp"
                android:backgroundTint="#00E676"
                android:fontFamily="sans-serif-condensed"
                android:padding="0dp"
                android:text="SETUP"
                android:textColor="#01051a"
                android:textStyle="bold"
                android:textSize="13sp"
                app:cornerRadius="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="HardcodedText" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_manage_matches"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#131833"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintWidth_percent="0.95"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_set_match">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:minHeight="115dp">

            <TextView
                android:id="@+id/tv_title_manage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="sans-serif-condensed"
                android:text="Manage Live Matches"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/btn_manage_matches"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tv_manage_matches_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="16dp"
                android:text="Track stats, fouls, goals, and events for ongoing games."
                android:textColor="#888888"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@+id/btn_manage_matches"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_title_manage"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/btn_manage_matches"
                android:layout_width="85dp"
                android:layout_height="48dp"
                android:backgroundTint="#FFFFFF"
                android:fontFamily="sans-serif-condensed"
                android:padding="0dp"
                android:text="VIEW"
                android:textColor="#01051a"
                android:textStyle="bold"
                android:textSize="13sp"
                app:cornerRadius="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="HardcodedText" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>