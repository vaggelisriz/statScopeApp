<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp"
    tools:context=".StatisticianActivity">

    <ImageButton
        android:id="@+id/btn_back_dashboard"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00E676" />

    <TextView
        android:id="@+id/tv_dashboard_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="sans-serif-condensed"
        android:text="STATISTICIAN DASHBOARD"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_dashboard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_back_dashboard"
        app:layout_constraintTop_toTopOf="@+id/btn_back_dashboard" />

    <View
        android:id="@+id/accent_line"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:background="#00E676"
        app:layout_constraintStart_toStartOf="@+id/tv_dashboard_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_dashboard_title" />

    <Button
        android:id="@+id/btn_set_match_live"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="60dp"
        android:backgroundTint="#00E676"
        android:fontFamily="sans-serif-condensed"
        android:text="SET MATCH LIVE"
        android:textColor="#01051a"
        android:textStyle="bold"
        app:cornerRadius="4dp"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/accent_line" />

    <Button
        android:id="@+id/btn_manage_matches"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FFFFFF"
        android:fontFamily="sans-serif-condensed"
        android:text="MANAGE LIVE MATCHES"
        android:textColor="#01051a"
        android:textStyle="bold"
        app:cornerRadius="4dp"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_set_match_live" />

</androidx.constraintlayout.widget.ConstraintLayout>