<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btn_back_actions"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00E676" />

    <TextView
        android:id="@+id/tv_actions_static_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="sans-serif-condensed"
        android:text="MANAGE LIVE MATCHES"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_back_actions"
        app:layout_constraintTop_toTopOf="@+id/btn_back_actions" />

    <View
        android:id="@+id/accent_line"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:background="#00E676"
        app:layout_constraintStart_toStartOf="@+id/tv_actions_static_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_actions_static_title" />

    <include
        android:id="@+id/included_match_card"
        layout="@layout/item_match"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/accent_line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/included_match_card">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_lineups"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:text="UPDATE LINEUPS"
            android:textColor="#00E676"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            app:backgroundTint="#131833"
            app:rippleColor="#3300E676"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="26dp"
            app:iconTint="#00E676"
            app:strokeColor="#00E676"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_statistics"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:text="ADD LIVE STATISTICS"
            android:textColor="#00E676"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            app:backgroundTint="#131833"
            app:rippleColor="#3300E676"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="26dp"
            app:iconTint="#00E676"
            app:strokeColor="#00E676"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_finish_match"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="FINISH MATCH"
            android:textColor="#FF5252"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            app:backgroundTint="#131833"
            app:rippleColor="#33FF5252"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="26dp"
            app:iconTint="#FF5252"
            app:strokeColor="#FF5252"
            app:strokeWidth="1.5dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>