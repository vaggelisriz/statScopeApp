<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btn_back_control"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="-8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00E676" />

    <TextView
        android:id="@+id/tv_control_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:fontFamily="sans-serif-condensed"
        android:text="MATCH LIVE CONTROL"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_control"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_back_control"
        app:layout_constraintTop_toTopOf="@+id/btn_back_control" />

    <View
        android:id="@+id/accent_line"
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:background="#00E676"
        app:layout_constraintStart_toStartOf="@+id/tv_control_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_control_title" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/accent_line">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/iv_home_logo_control"
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    app:layout_constraintEnd_toStartOf="@+id/tv_vs"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_vs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VS"
                    android:textColor="#00E676"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_home_logo_control"
                    app:layout_constraintEnd_toStartOf="@+id/iv_away_logo_control"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/iv_home_logo_control"
                    app:layout_constraintTop_toTopOf="@+id/iv_home_logo_control" />

                <ImageView
                    android:id="@+id/iv_away_logo_control"
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/tv_vs"
                    app:layout_constraintTop_toTopOf="@+id/iv_home_logo_control" />

                <TextView
                    android:id="@+id/tv_home_name_control"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@+id/iv_home_logo_control"
                    app:layout_constraintStart_toStartOf="@+id/iv_home_logo_control"
                    app:layout_constraintTop_toBottomOf="@+id/iv_home_logo_control" />

                <TextView
                    android:id="@+id/tv_away_name_control"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@+id/iv_away_logo_control"
                    app:layout_constraintStart_toStartOf="@+id/iv_away_logo_control"
                    app:layout_constraintTop_toBottomOf="@+id/iv_away_logo_control" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#1AFFFFFF" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#131833"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <Button
                        android:id="@+id/btn_select_home"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:backgroundTint="#1D244D"
                        android:text="SELECT HOME LINEUP"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="6dp" />
                    <TextView
                        android:id="@+id/tv_home_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Please add players"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#131833"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <Button
                        android:id="@+id/btn_select_away"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:backgroundTint="#1D244D"
                        android:text="SELECT AWAY LINEUP"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="6dp" />
                    <TextView
                        android:id="@+id/tv_away_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Please add players"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_start_live"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#444444"
                android:enabled="false"
                android:text="START MATCH"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>