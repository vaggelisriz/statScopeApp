<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01051a"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btn_back_control"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00E676" />

    <TextView
        android:id="@+id/tv_control_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="sans-serif-condensed"
        android:text="MATCH LIVE CONTROL"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_control"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_back_control"
        app:layout_constraintTop_toTopOf="@+id/btn_back_control" />

    <View
        android:id="@+id/accent_line"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:background="#00E676"
        app:layout_constraintStart_toStartOf="@+id/tv_control_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_control_title" />

    <ImageView
        android:id="@+id/iv_home_logo_control"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="80dp"
        app:layout_constraintEnd_toStartOf="@+id/tv_vs"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/accent_line" />

    <TextView
        android:id="@+id/tv_vs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"
        android:text="VS"
        android:textColor="#00E676"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/iv_home_logo_control"
        app:layout_constraintEnd_toStartOf="@+id/iv_away_logo_control"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/iv_home_logo_control"
        app:layout_constraintTop_toTopOf="@+id/iv_home_logo_control" />

    <ImageView
        android:id="@+id/iv_away_logo_control"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/tv_vs"
        app:layout_constraintTop_toTopOf="@+id/iv_home_logo_control" />

    <TextView
        android:id="@+id/tv_home_name_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-condensed"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/iv_home_logo_control"
        app:layout_constraintStart_toStartOf="@+id/iv_home_logo_control"
        app:layout_constraintTop_toBottomOf="@+id/iv_home_logo_control" />

    <TextView
        android:id="@+id/tv_away_name_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-condensed"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/iv_away_logo_control"
        app:layout_constraintStart_toStartOf="@+id/iv_away_logo_control"
        app:layout_constraintTop_toBottomOf="@+id/iv_away_logo_control" />

    <TextView
        android:id="@+id/tv_status_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="sans-serif-condensed"
        android:textColor="#00E676"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_home_name_control" />

    <Button
        android:id="@+id/btn_start_live"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="60dp"
        android:backgroundTint="#00E676"
        android:fontFamily="sans-serif-condensed"
        android:text="START LIVE"
        android:textColor="#01051a"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_status_control"
        app:layout_constraintWidth_percent="0.85" />

</androidx.constraintlayout.widget.ConstraintLayout>